@import "catppuccin-mocha.css";

*{
    font-size:17px;
    font-family: "Hack Nerd Font Propo";
    min-height: 0;
}

#waybar {
    background:transparent;
    color:@text;
    margin:5px 5px;
}

#workspaces {
	border-radius: 1rem;
	margin: 5px;
    background-color: @surface0;
	margin-left: 1rem;
}

#workspaces button {
    color: @lavander;
    border-radius: 1rem;
    padding: 0.4rem;
}

#workspaces button.active {
    color: @sapphire;
    border-radius: 1rem;
}

#workspaces button:hover {
    color: @mauve;
    border-radius: 1rem;
    transition: all .3s ease;
}

#workspaces button.focused {
	color: @sky;
    border-radius: 1rem;
    transition: all .3s ease;
}

#clock {
    color: @blue;
    background-color:@surface0;
    border-radius: 1rem;
}

#clock:hover,
#hardware-sensors:hover {
    transition: all .3s ease;
    color:@mauve;
}

#bluetooth{
    padding: 0px 5px;
    transition: all .3s ease;
    color:@text;

}

#bluetooth.connected.good{
    color:@green;
}

#bluetooth.connected.warning{
    color:@yellow;
}


#bluetooth.connected.warning{
    color:@red;
}

#network{
    padding: 0px 5px;
    transition: all .3s ease;
    color:@text;

}

#network{
    color:@green;
}

#network.disconnected{
    color:@red;
}

#network.disabled{
    color:@red;
}

#battery{
    padding: 0px 5px;
    transition: all .3s ease;
    color:@text;
}

#battery.plugged {
    color: @green;
}

#battery.charging {
    color: @green;
    animation-name: blink;
    animation-duration: 1s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

#battery.warning:not(.charging) {
    color: @yellow;
}

#battery.critical:not(.charging) {
    color: @red;
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}
